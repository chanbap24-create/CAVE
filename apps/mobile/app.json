{
  "expo": {
    "name": "Cave",
    "slug": "cave",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "i-cellar",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.icellar.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.icellar.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow I Cellar to access your camera to scan wine labels."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow I Cellar to access your photos to share wine moments."
        }
      ],
      "expo-web-browser",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-video"
    ]
  }
}
